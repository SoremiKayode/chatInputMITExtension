{
  "$schema": "vscode://schemas/color-theme",
  "name": "No White Contrast",
  "type": "dark",
  "colors": {
    "editor.background": "#101820",
    "editor.foreground": "#A7B3C2",
    "editorLineNumber.foreground": "#52677A",
    "editorLineNumber.activeForeground": "#7AA2F7",
    "editorCursor.foreground": "#4DD0E1",
    "editor.selectionBackground": "#334155",
    "editor.inactiveSelectionBackground": "#243447",
    "editor.lineHighlightBackground": "#172A3A",
    "editorIndentGuide.background1": "#263849",
    "editorIndentGuide.activeBackground1": "#4DD0E1",
    "sideBar.background": "#0D141C",
    "activityBar.background": "#0A1118",
    "statusBar.background": "#121E2A",
    "titleBar.activeBackground": "#0A1118",
    "panel.background": "#0D141C",
    "terminal.background": "#101820",
    "terminal.foreground": "#A7B3C2",
    "terminal.ansiBlack": "#0A1118",
    "terminal.ansiRed": "#FF5555",
    "terminal.ansiGreen": "#9ECE6A",
    "terminal.ansiYellow": "#E0AF68",
    "terminal.ansiBlue": "#7AA2F7",
    "terminal.ansiMagenta": "#C792EA",
    "terminal.ansiCyan": "#4DD0E1",
    "terminal.ansiWhite": "#A7B3C2",
    "terminal.ansiBrightBlack": "#52677A",
    "terminal.ansiBrightRed": "#F7768E",
    "terminal.ansiBrightGreen": "#B9F27C",
    "terminal.ansiBrightYellow": "#FFB86C",
    "terminal.ansiBrightBlue": "#89B4FA",
    "terminal.ansiBrightMagenta": "#FF79C6",
    "terminal.ansiBrightCyan": "#73DACA",
    "terminal.ansiBrightWhite": "#C0CAD8",
    "editorBracketHighlight.foreground1": "#4DD0E1",
    "editorBracketHighlight.foreground2": "#B48EFA",
    "editorBracketHighlight.foreground3": "#E0AF68",
    "editorBracketHighlight.foreground4": "#9ECE6A",
    "editorBracketHighlight.foreground5": "#F7768E",
    "editorBracketHighlight.foreground6": "#73DACA",
    "gitDecoration.addedResourceForeground": "#9ECE6A",
    "gitDecoration.modifiedResourceForeground": "#FFB86C",
    "gitDecoration.deletedResourceForeground": "#FF5555",
    "gitDecoration.renamedResourceForeground": "#4DD0E1",
    "gitDecoration.untrackedResourceForeground": "#73DACA",
    "gitDecoration.ignoredResourceForeground": "#52677A",
    "diffEditor.insertedTextBackground": "#1E3A2F",
    "diffEditor.removedTextBackground": "#4A1F2A",
    "diffEditor.insertedLineBackground": "#142D24",
    "diffEditor.removedLineBackground": "#351A22",
    "editorError.foreground": "#FF5555",
    "editorWarning.foreground": "#FFB86C",
    "editorInfo.foreground": "#4DD0E1",
    "editorHint.foreground": "#73DACA"
  },
  "tokenColors": [
    {"scope": "comment", "settings": {"foreground": "#6A8F7A", "fontStyle": "italic"}},
    {"scope": "comment.block.documentation", "settings": {"foreground": "#7FAE8C"}},
    {"scope": "keyword", "settings": {"foreground": "#B48EFA"}},
    {"scope": "keyword.control", "settings": {"foreground": "#C678DD"}},
    {"scope": "keyword.operator", "settings": {"foreground": "#FF79C6"}},
    {"scope": "storage", "settings": {"foreground": "#FF79C6"}},
    {"scope": "storage.type", "settings": {"foreground": "#FFCB6B"}},
    {"scope": "storage.modifier", "settings": {"foreground": "#FF79C6"}},
    {"scope": "entity.name.function", "settings": {"foreground": "#4DD0E1"}},
    {"scope": "support.function", "settings": {"foreground": "#00BFD8"}},
    {"scope": "variable", "settings": {"foreground": "#7AA2F7"}},
    {"scope": "variable.other", "settings": {"foreground": "#89B4FA"}},
    {"scope": "variable.parameter", "settings": {"foreground": "#E0AF68"}},
    {"scope": "variable.language", "settings": {"foreground": "#FF9E64"}},
    {"scope": "constant", "settings": {"foreground": "#FFB86C"}},
    {"scope": "constant.numeric", "settings": {"foreground": "#F7768E"}},
    {"scope": "constant.language", "settings": {"foreground": "#FF9E64"}},
    {"scope": "string", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "string.quoted", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "string.template", "settings": {"foreground": "#87C95F"}},
    {"scope": "constant.character.escape", "settings": {"foreground": "#FFB86C"}},
    {"scope": "punctuation", "settings": {"foreground": "#6C8AA6"}},
    {"scope": "punctuation.definition", "settings": {"foreground": "#89DDFF"}},
    {"scope": "punctuation.separator", "settings": {"foreground": "#6C8AA6"}},
    {"scope": "meta.brace", "settings": {"foreground": "#89DDFF"}},
    {"scope": "invalid", "settings": {"foreground": "#FF5555", "fontStyle": "underline"}},
    {"scope": "invalid.deprecated", "settings": {"foreground": "#8B5E6E", "fontStyle": "strikethrough"}},

    {"scope": "variable.other.constant.js", "settings": {"foreground": "#FFB86C"}},
    {"scope": "variable.other.readwrite.js", "settings": {"foreground": "#89B4FA"}},
    {"scope": "support.class.console.js", "settings": {"foreground": "#C792EA"}},
    {"scope": "meta.object-literal.key.js", "settings": {"foreground": "#5EEAD4"}},
    {"scope": "entity.name.type.class.js", "settings": {"foreground": "#E0AF68"}},
    {"scope": "entity.name.type.interface.ts", "settings": {"foreground": "#F2B86D"}},
    {"scope": "entity.name.type.enum.ts", "settings": {"foreground": "#D19A66"}},
    {"scope": "support.type.primitive.ts", "settings": {"foreground": "#FFCB6B"}},
    {"scope": "keyword.control.import.js", "settings": {"foreground": "#C792EA"}},
    {"scope": "keyword.control.export.js", "settings": {"foreground": "#C792EA"}},
    {"scope": "meta.import.js", "settings": {"foreground": "#C792EA"}},
    {"scope": "meta.export.js", "settings": {"foreground": "#C792EA"}},
    {"scope": "variable.parameter.ts", "settings": {"foreground": "#E0AF68"}},
    {"scope": "punctuation.definition.template-expression", "settings": {"foreground": "#FF79C6"}},
    {"scope": "support.type.property-name.json", "settings": {"foreground": "#73DACA"}},

    {"scope": "variable.parameter.function.language.python", "settings": {"foreground": "#E0AF68"}},
    {"scope": "entity.name.function.python", "settings": {"foreground": "#4DD0E1"}},
    {"scope": "support.function.builtin.python", "settings": {"foreground": "#00BFD8"}},
    {"scope": "support.type.python", "settings": {"foreground": "#FFCB6B"}},
    {"scope": "storage.type.function.python", "settings": {"foreground": "#C678DD"}},
    {"scope": "keyword.control.import.python", "settings": {"foreground": "#C792EA"}},
    {"scope": "constant.language.python", "settings": {"foreground": "#FF9E64"}},
    {"scope": "variable.language.self.python", "settings": {"foreground": "#FF9E64", "fontStyle": "italic"}},
    {"scope": "meta.function-call.python", "settings": {"foreground": "#2EC4B6"}},
    {"scope": "punctuation.separator.parameters.python", "settings": {"foreground": "#6C8AA6"}},

    {"scope": "entity.name.tag.html", "settings": {"foreground": "#F7768E"}},
    {"scope": "entity.other.attribute-name.html", "settings": {"foreground": "#E0AF68"}},
    {"scope": "string.quoted.double.html", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "punctuation.definition.tag.html", "settings": {"foreground": "#89DDFF"}},
    {"scope": "text.html.derivative", "settings": {"foreground": "#A7B3C2"}},

    {"scope": "entity.name.tag.css", "settings": {"foreground": "#C792EA"}},
    {"scope": "entity.other.attribute-name.class.css", "settings": {"foreground": "#5EEAD4"}},
    {"scope": "entity.other.attribute-name.id.css", "settings": {"foreground": "#4DD0E1"}},
    {"scope": "support.type.property-name.css", "settings": {"foreground": "#73DACA"}},
    {"scope": "support.constant.property-value.css", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "constant.numeric.css", "settings": {"foreground": "#F7768E"}},
    {"scope": "keyword.other.unit.css", "settings": {"foreground": "#E0AF68"}},
    {"scope": "punctuation.definition.entity.css", "settings": {"foreground": "#89DDFF"}},
    {"scope": "meta.selector.css", "settings": {"foreground": "#C792EA"}},

    {"scope": "string.quoted.double.json", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "constant.numeric.json", "settings": {"foreground": "#F7768E"}},
    {"scope": "constant.language.json", "settings": {"foreground": "#FF9E64"}},
    {"scope": "punctuation.separator.dictionary.key-value.json", "settings": {"foreground": "#FF79C6"}},

    {"scope": "markup.heading", "settings": {"foreground": "#4DD0E1", "fontStyle": "bold"}},
    {"scope": "markup.bold", "settings": {"foreground": "#E0AF68", "fontStyle": "bold"}},
    {"scope": "markup.italic", "settings": {"foreground": "#C792EA", "fontStyle": "italic"}},
    {"scope": "markup.inline.raw", "settings": {"foreground": "#9ECE6A"}},
    {"scope": "markup.fenced_code.block", "settings": {"foreground": "#87C95F"}},
    {"scope": "markup.underline.link", "settings": {"foreground": "#7AA2F7", "fontStyle": "underline"}},
    {"scope": "string.other.link", "settings": {"foreground": "#7AA2F7"}},
    {"scope": "punctuation.definition.heading.markdown", "settings": {"foreground": "#4DD0E1"}},
    {"scope": "punctuation.definition.raw.markdown", "settings": {"foreground": "#87C95F"}}
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#C792EA",
    "class": {"foreground": "#E0AF68", "fontStyle": "bold"},
    "enum": "#D19A66",
    "interface": {"foreground": "#F2B86D", "fontStyle": "bold"},
    "struct": "#FFCB6B",
    "typeParameter": "#C792EA",
    "type": "#FFCB6B",
    "parameter": "#E0AF68",
    "variable": "#7AA2F7",
    "property": "#73DACA",
    "enumMember": "#FFB86C",
    "event": "#4DD0E1",
    "function": "#4DD0E1",
    "method": "#2EC4B6",
    "macro": "#F2B86D",
    "keyword": "#B48EFA",
    "modifier": "#FF79C6",
    "comment": "#6A8F7A",
    "string": "#9ECE6A",
    "number": "#F7768E",
    "regexp": "#FFB86C",
    "operator": "#FF79C6",
    "decorator": "#F2B86D",

    "variable.readonly": "#E0AF68",
    "property.readonly": "#E0AF68",
    "method.static": "#4DD0E1",
    "property.static": "#4DD0E1",
    "*.deprecated": {"foreground": "#8B5E6E", "fontStyle": "strikethrough"},
    "function.async": {"foreground": "#4DD0E1", "fontStyle": "italic"},
    "method.async": {"foreground": "#2EC4B6", "fontStyle": "italic"},
    "*.declaration": {"fontStyle": "bold"},
    "*.defaultLibrary": "#6C8AA6"
  }
}
